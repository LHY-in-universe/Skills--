            "hit_or_miss",
            "stratified",
            "importance",
            "control_variates",
            "all"
          ],
          "description": "积分方法；'all' 同时运行所有方法并输出横向对比，按误差从小到大排序",
          "default": "crude"
        },
        "func": {
          "type": "string",
          "enum": [
            "sin",
            "x2",
            "exp"
          ],
          "description": "被积函数：sin=sin(x)（真实值≈0.4597），x2=x²（真实值=1/3），exp=e^x（真实值≈1.7183），区间均为 [0,1]",
          "default": "sin"
        },
        "n": {
          "type": "integer",
          "minimum": 1,
          "description": "随机采样点数，越大精度越高但耗时越长，推荐范围 10000~1000000",
          "default": 100000
        },
        "seed": {
          "type": "integer",
          "description": "随机种子，固定后结果完全可复现；'all' 模式下每种方法使用相同种子保证公平对比",
          "default": 42
        }
      },
      "required": []
    }
  }
